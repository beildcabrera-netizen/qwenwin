generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  ci              String    @unique
  firstName       String
  lastName        String
  email           String?   @unique
  phone           String?
  barcode         String?   @unique
  password        String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  attendanceEnabled Boolean   @default(false)
  paymentType     PaymentType @default(NONE)
  paymentBase     PaymentBase @default(FIXED_AMOUNT)
  hourlyRate      Decimal?  @db.Decimal(10, 2)
  fixedAmount     Decimal?  @db.Decimal(10, 2)
  active          Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  enrollments     Enrollment[]
  payments        Payment[]
  attendances     Attendance[]
  timeBlocks      TimeBlock[]
  turns           Turn[]
  withdrawals     Withdrawal[]
  expenses        Expense[]
  @@index([ci])
  @@index([barcode])
  @@index([roleId])
}

model Role {
  id              String    @id @default(uuid())
  name            String    @unique
  description     String?
  systemAccess    Boolean   @default(false)
  attendanceEnabled Boolean @default(false)
  latePolicy      LatePolicy @default(NONE)
  lateGraceMinutes Int       @default(0)
  earlyDeparturePolicy EarlyPolicy @default(NONE)
  extraHoursPolicy ExtraHoursPolicy @default(NONE)
  extraHoursLimit Decimal?  @db.Decimal(5, 2)
  minHoursToPay   Decimal?  @db.Decimal(5, 2)
  autoClockOut    Boolean   @default(false)
  permissions     Permission[]
  users           User[]
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  @@unique([module, action])
}

model Plan {
  id            String    @id @default(uuid())
  name          String
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  durationDays  Int
  type          PlanType
  active        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  enrollments   Enrollment[]
}

model Group {
  id                String    @id @default(uuid())
  name              String
  scheduleStart     String
  scheduleEnd       String
  daysOfWeek        Int[]
  maxCapacity       Int
  level             String?
  toleranceMinutes  Int       @default(5)
  professorId       String?
  professor         User?     @relation(fields: [professorId], references: [id])
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enrollments       Enrollment[]
}

model Enrollment {
  id            String         @id @default(uuid())
  studentId     String
  student       User           @relation(fields: [studentId], references: [id])
  groupId       String
  group         Group          @relation(fields: [groupId], references: [id])
  planId        String
  plan          Plan           @relation(fields: [planId], references: [id])
  startDate     DateTime       @default(now())
  endDate       DateTime
  status        EnrollmentStatus @default(ACTIVE)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payments      Payment[]
  attendances   Attendance[]
  freezes       EnrollmentFreeze[]
}

model EnrollmentFreeze {
  id            String    @id @default(uuid())
  enrollmentId  String
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id])
  reason        String
  days          Int
  startDate     DateTime  @default(now())
  endDate       DateTime
  actualEndDate DateTime?
  daysUsed      Int?
  status        FreezeStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
}

model Payment {
  id              String    @id @default(uuid())
  enrollmentId    String
  enrollment      Enrollment @relation(fields: [enrollmentId], references: [id])
  amount          Decimal   @db.Decimal(10, 2)
  originalAmount  Decimal   @db.Decimal(10, 2)
  discountAmount  Decimal   @db.Decimal(10, 2) @default(0)
  discountReason  String?
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  turnId          String?
  turn            Turn?     @relation(fields: [turnId], references: [id])
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
}

model Attendance {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  enrollmentId  String?
  enrollment    Enrollment?    @relation(fields: [enrollmentId], references: [id])
  checkIn       DateTime
  checkOut      DateTime?
  date          DateTime       @default(now())
  status        AttendanceStatus @default(PRESENT)
  method        CheckInMethod  @default(BARCODE)
  notes         String?
  createdAt     DateTime       @default(now())
}

model TimeBlock {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  dayOfWeek     Int
  startTime     String
  endTime       String
  groupId       String?
  createdAt     DateTime  @default(now())
}

model Turn {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  initialAmount   Decimal   @db.Decimal(10, 2)
  finalAmount     Decimal?  @db.Decimal(10, 2)
  discrepancy     Decimal?  @db.Decimal(10, 2)
  status          TurnStatus @default(OPEN)
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  observations    String?
  deletedAt       DateTime?
  payments        Payment[]
  withdrawals     Withdrawal[]
  expenses        Expense[]
}

model Withdrawal {
  id            String    @id @default(uuid())
  turnId        String
  turn          Turn      @relation(fields: [turnId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Decimal   @db.Decimal(10, 2)
  reason        String
  createdAt     DateTime  @default(now())
}

model Expense {
  id            String    @id @default(uuid())
  turnId        String
  turn          Turn      @relation(fields: [turnId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Decimal   @db.Decimal(10, 2)
  category      String
  description   String?
  createdAt     DateTime  @default(now())
}

model MessageTemplate {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  message     String
  placeholders String[]
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum PaymentType {
  NONE
  HOURLY
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PaymentBase {
  ATTENDANCE_HOURS
  FIXED_AMOUNT
  MIXED
}

enum LatePolicy {
  NONE
  PRORATE
  BLOCK
}

enum EarlyPolicy {
  NONE
  PRORATE
  BLOCK
}

enum ExtraHoursPolicy {
  NONE
  BLOCK_LIMIT
  TIME_LIMIT
  FULL_PAY
}

enum PlanType {
  REGULAR
  INTENSIVE
  SUMMER
  PRIVATE
  THERAPEUTIC
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  FROZEN
  COMPLETED
}

enum FreezeStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  QR
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_DEPARTURE
}

enum CheckInMethod {
  BARCODE
  MANUAL
}

enum TurnStatus {
  OPEN
  CLOSED
}
